<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eye Health Analytics</title>
    <!-- Modern font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="/static/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
</head>

<body>
    <!-- Toast Container for Health Alerts -->
    <div id="toast-container"></div>

    <div class="dashboard">

        <h1>Eye Health Monitor AI</h1>

        <!-- Daily Progress Section -->
        <div class="goals-section">
            <div class="ring-card ring-blinks">
                <h3>Total Blinks</h3>
                <svg viewBox="0 0 36 36" class="circular-chart">
                    <path class="circle-bg"
                        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                    />
                    <path class="circle" id="blink-ring"
                        stroke-dasharray="0, 100"
                        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                    />
                    <text x="18" y="20.35" class="percentage" id="blink-count-text">0</text>
                    <text x="18" y="26" class="sub-text">/ 2000</text>
                </svg>
            </div>

            <div class="ring-card ring-screen">
                <h3>Screen Time</h3>
                <svg viewBox="0 0 36 36" class="circular-chart">
                    <path class="circle-bg"
                        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                    />
                    <path class="circle" id="screen-ring"
                        stroke-dasharray="0, 100"
                        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                    />
                    <text x="18" y="20.35" class="percentage" id="screen-time-text">0m</text>
                    <text x="18" y="26" class="sub-text">/ 480m</text>
                </svg>
            </div>

            <div class="ring-card ring-health">
                <h3>Avg Health</h3>
                <svg viewBox="0 0 36 36" class="circular-chart">
                    <path class="circle-bg"
                        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                    />
                    <path class="circle" id="health-ring"
                        stroke-dasharray="0, 100"
                        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                    />
                    <text x="18" y="20.35" class="percentage" id="avg-health-text">0%</text>
                    <text x="18" y="26" class="sub-text">Overall</text>
                </svg>
            </div>
        </div>

        <h2 class="section-title">Deep Analytics</h2>
        <div class="analytics-grid">
            <div class="analytics-card heatmap-card">
                <h3>Eye-Health Consistency Heatmap</h3>
                <div id="heatmap-container" class="heatmap-container"></div>
                <div class="heatmap-legend">
                    <span>Needs Work</span>
                    <div class="legend-scale">
                        <span class="cell level-1"></span>
                        <span class="cell level-2"></span>
                        <span class="cell level-3"></span>
                        <span class="cell level-4"></span>
                    </div>
                    <span>Excellent</span>
                </div>
            </div>
            
            <div class="analytics-card">
                <div class="chart-container">
                    <canvas id="weeklyChart"></canvas>
                </div>
            </div>
            
            <div class="analytics-card full-width">
                <h3>Today's Productivity Timeline</h3>
                <div class="timeline-x-axis">
                    <span>12:00 AM</span><span>06:00 AM</span><span>12:00 PM</span><span>06:00 PM</span><span>12:00 AM</span>
                </div>
                <div id="timeline-container" class="timeline-container"></div>
            </div>
        </div>

        <div class="analytics-grid">
            <div class="analytics-card full-width">
                <h3>Find Nearby Eye Specialists</h3>
                <button id="locate-btn" class="btn-primary">Locate Me + Show Nearby Doctors</button>
                <div id="map-container" class="map-container">Allow location to show map</div>
                <div id="map-status" class="map-status"></div>
            </div>
        </div>

        <div class="grid">

            <div class="card">
                <h3>Current Activity</h3>
                <p id="activity">--</p>
            </div>

            <div class="card">
                <h3>Screen Distance</h3>
                <p id="distance">--</p>
            </div>

            <div class="card">
                <h3>Blink Rate</h3>
                <p id="blink">--</p>
            </div>
        </div>

        <div class="charts-grid">
            <div class="chart-card">
                <canvas id="fatigueChart"></canvas>
            </div>

            <div class="chart-card">
                <canvas id="blinkChart"></canvas>
            </div>

            <div class="chart-card">
                <canvas id="distanceChart"></canvas>
            </div>
        </div>

    </div>

    <!-- Chat Widget -->
    <div class="chat-widget" id="chat-widget">
        <div class="chat-header" id="chat-header" onclick="toggleChat()">
            <span>Ask AI Health Assistant ✨</span>
            <button id="chat-toggle">—</button>
        </div>
        <div class="chat-body" id="chat-body">
            <div class="chat-message bot">Hello! I'm your world-class AI assistant. Ask me anything about science, history, coding, or even just for a quick chat! 🌐</div>
        </div>
        <div class="chat-input-area">
            <input type="text" id="chat-input" placeholder="Type a message..." onkeypress="if(event.key === 'Enter') sendChat()">
            <button onclick="sendChat()">Send</button>
        </div>
    </div>

    <script src="/static/dashboard.js"></script>

</body>
</html>
